# ============================================================================
# AudioSmith AI — .gitignore
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.pytype/

# ---------------------------------------------------------------------------
# Node.js / Frontend
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# ML / Data
# ---------------------------------------------------------------------------
# Model checkpoints and weights
*.pt
*.pth
*.onnx
*.bin
checkpoints/
weights/

# Datasets (large files — download via scripts)
data/raw/
data/processed/
data/external/
datasets/

# Experiment outputs
runs/
logs/
mlruns/
wandb/

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
*.log
tmp/
temp/

# ---------------------------------------------------------------------------
# Audio outputs (generated at runtime)
# ---------------------------------------------------------------------------
uploads/
enhanced/
visualizations/
