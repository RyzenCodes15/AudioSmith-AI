# ============================================================================
# AudioSmith AI — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_USER=audiosmith
POSTGRES_PASSWORD=audiosmith_dev_password
POSTGRES_DB=audiosmith
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# For S3-compatible storage (production):
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=audiosmith-uploads
# AWS_S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# ML / Inference
# ---------------------------------------------------------------------------
ML_MODEL_NAME=deepfilternet
ML_MODEL_CHECKPOINT_PATH=
ML_DEVICE=cpu
ML_MAX_AUDIO_DURATION_SECONDS=300
ML_SAMPLE_RATE=48000

# ---------------------------------------------------------------------------
# Celery (Task Queue)
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/1

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=AudioSmith AI
